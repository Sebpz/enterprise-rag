# ─────────────────────────────────────────────────────────────────
#  Enterprise RAG Platform — Environment Variables
#  Copy to .env and fill in your values
#  Never commit .env to git!
# ─────────────────────────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────────────────────────
LLM_PROVIDER=openai               # "openai" or "ollama"
OPENAI_API_KEY=sk-...             # Required if LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini          # Pin to a specific version in prod
OLLAMA_BASE_URL=http://ollama:11434  # Used if LLM_PROVIDER=ollama
OLLAMA_MODEL=mistral              # Model to use with Ollama

# ── Embedding Model ───────────────────────────────────────────────
EMBEDDING_PROVIDER=local          # "local" (sentence-transformers) or "openai"
EMBEDDING_MODEL=all-MiniLM-L6-v2  # Local model name
OPENAI_EMBEDDING_MODEL=text-embedding-3-small  # If EMBEDDING_PROVIDER=openai

# ── Retrieval ─────────────────────────────────────────────────────
COHERE_API_KEY=                   # For reranking — get free key at cohere.com
RERANKER_PROVIDER=cohere          # "cohere" or "local" (cross-encoder)
RERANKER_TOP_N=5                  # How many chunks to pass to LLM after rerank
RETRIEVAL_TOP_K=50                # How many candidates to retrieve before rerank

# ── Vector Store ──────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=arxiv_papers
QDRANT_API_KEY=                   # Leave blank for local Qdrant

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://raguser:ragpass@localhost:5432/ragdb

# ── Cache + Rate Limiting ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── API Security ──────────────────────────────────────────────────
API_KEY_HEADER=X-API-Key
DEV_API_KEY=dev-key-local          # Used in local development only
RATE_LIMIT_PER_MINUTE=20           # Requests per user per minute
RATE_LIMIT_TOKENS_PER_DAY=100000   # Token budget per user per day

# ── Observability ─────────────────────────────────────────────────
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=              # Create project in Langfuse UI first
LANGFUSE_SECRET_KEY=              # Create project in Langfuse UI first

# ── Guardrails ────────────────────────────────────────────────────
GUARDRAILS_ENABLED=true
TOPIC_FILTER_THRESHOLD=0.7        # Confidence threshold for off-topic blocking
FAITHFULNESS_THRESHOLD=0.6        # Block output if faithfulness score below this
MAX_AGENT_ITERATIONS=3            # Max critique loops before force-exit
MAX_AGENT_TOKENS=8000             # Budget guardrail per conversation

# ── Chunking ──────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50
CHUNKING_STRATEGY=recursive       # "recursive" or "semantic"

# ── Fine-tuned Model (Module 9) ───────────────────────────────────
FINETUNED_MODEL_PATH=             # Path to LoRA adapter after training
USE_FINETUNED_CITATIONS=false     # Enable once model is trained and tested

# ── Frontend ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Weights & Biases (Module 9) ───────────────────────────────────
WANDB_API_KEY=                    # Get from wandb.ai
WANDB_PROJECT=enterprise-rag-finetune
